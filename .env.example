# Copy to `.env` here OR `artifacts/instacollab/.env` (app loads both).
# Restart `pnpm dev` after editing.

# Vercel sandbox / preview deploys (set in vercel.json for hosted builds)
# NODE_ENV=sandbox

# Production app URL (Vercel custom domain)
# VITE_APP_ORIGIN=https://app.uniapplab.com

VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key

# Optional — also accepted as VITE_SUPABASE_PUBLISHABLE_KEY
# VITE_FIREBASE_* — only if using Firebase failover
