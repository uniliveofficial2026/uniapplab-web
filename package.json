{
  "name": "workspace",
  "version": "0.0.0",
  "license": "MIT",
  "packageManager": "pnpm@10.34.4",
  "scripts": {
    "preinstall": "sh -c 'rm -f package-lock.json yarn.lock; case \"$npm_config_user_agent\" in pnpm/*) ;; *) echo \"Use pnpm instead\" >&2; exit 1 ;; esac'",
    "postinstall": "node scripts/ensure-live.mjs",
    "setup": "bash scripts/ensure-pnpm.sh && node scripts/ensure-live.mjs",
    "build": "pnpm -r --filter \"./artifacts/instacollab\" --filter \"./artifacts/api-server\" --if-present run build",
    "typecheck:libs": "tsc --build",
    "typecheck": "pnpm run typecheck:libs && pnpm -r --filter \"./artifacts/**\" --filter \"./scripts\" --if-present run typecheck",
    "dev": "node scripts/live-sync.mjs",
    "develop": "node scripts/live-sync.mjs",
    "live": "node scripts/live-sync.mjs",
    "ensure:live": "node scripts/ensure-live.mjs",
    "dev:mobile": "pnpm --filter @workspace/instacollab run dev:mobile",
    "mobile:preview": "pnpm --filter @workspace/instacollab run mobile:preview",
    "mobile:live": "pnpm --filter @workspace/instacollab run mobile:live",
    "auth:bootstrap-db": "pnpm --filter @workspace/instacollab run auth:bootstrap-db",
    "auth:repair-policies": "pnpm --filter @workspace/instacollab run auth:repair-policies",
    "auth:check": "pnpm --filter @workspace/instacollab run auth:check",
    "auth:check:prod": "pnpm --filter @workspace/instacollab run auth:check:prod",
    "oauth:setup": "pnpm --filter @workspace/instacollab run oauth:setup",
    "email-otp:setup": "pnpm --filter @workspace/instacollab run email-otp:setup",
    "email-otp:apply-template": "pnpm --filter @workspace/instacollab run email-otp:apply-template",
    "resend:test": "pnpm --filter @workspace/instacollab run resend:test",
    "email:setup": "pnpm --filter @workspace/instacollab run email:setup",
    "domains:setup": "node scripts/print-domains-setup.mjs",
    "git:push": "bash scripts/github-push.sh",
    "git:clean-history": "bash scripts/reset-clean-main.sh --yes",
    "deploy:vercel": "bash scripts/vercel-deploy.sh --prod",
    "deploy:vercel:git": "bash scripts/vercel-deploy-git.sh",
    "deploy:vercel:cli": "bash scripts/vercel-deploy.sh --prod",
    "deploy:vercel:fast": "VERCEL_PREBUILT=1 bash scripts/vercel-deploy.sh --prod",
    "deploy:vercel:full": "LIVE_SYNC_FULL_REPO=1 bash scripts/vercel-deploy.sh --prod",
    "heal": "node scripts/self-heal.mjs",
    "fix": "node scripts/auto-fix.mjs",
    "verify:prod": "node scripts/verify-production.mjs",
    "check:health": "node artifacts/instacollab/scripts/check-health.mjs",
    "ux:agent": "node scripts/background-ux-agent.mjs",
    "ux:learn": "node scripts/ux-learning-engine.mjs",
    "ux:gemini": "node scripts/ux-gemini-fix.mjs",
    "handoff": "node scripts/app-handoff.mjs",
    "handoff:cycle": "node scripts/app-handoff.mjs cycle"
  },
  "private": true,
  "devDependencies": {
    "prettier": "^3.8.3",
    "typescript": "~5.9.3"
  },
  "dependencies": {
    "@rollup/rollup-darwin-arm64": "4.60.3",
    "@tailwindcss/oxide-darwin-arm64": "4.1.14",
    "lightningcss-darwin-arm64": "1.32.0"
  }
}
