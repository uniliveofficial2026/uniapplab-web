rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() { return request.auth != null; }
    function isVerified() { return isSignedIn() && request.auth.token.email_verified == true; }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }

    // --- User Validation ---
    function isValidUser(data) {
      return data.keys().hasAll(['id', 'username', 'displayName', 'createdAt', 'updatedAt'])
        && data.id == request.auth.uid
        && data.username is string && data.username.size() >= 3 && data.username.size() <= 30
        && data.displayName is string && data.displayName.size() <= 64
        && data.createdAt == request.time
        && (data.bio == null || (data.bio is string && data.bio.size() <= 500))
        && (data.theme in ['light', 'dark'])
        && (data.language is string);
    }

    // --- Post Validation ---
    function isValidPost(data) {
      return data.userId == request.auth.uid
        && data.createdAt == request.time
        && data.content is string && data.content.size() <= 2200;
    }

    // --- Verification Requests Validation ---
    function isValidVerificationRequest(data) {
      return data.keys().hasAll(['userId', 'status', 'reason', 'createdAt'])
        && data.userId == request.auth.uid
        && data.status == 'pending'
        && data.reason is string && data.reason.size() <= 1000
        && data.createdAt == request.time;
    }

    // --- Collections ---

    match /users/{userId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn();
      allow create: if isOwner(userId) && isValidUser(incoming());
      allow update: if isOwner(userId) 
        && isValidUser(incoming())
        && incoming().diff(existing()).affectedKeys().hasOnly(['username', 'displayName', 'bio', 'avatarUrl', 'theme', 'language', 'updatedAt'])
        && incoming().username == existing().username; // Username is immutable after setup (optional choice)
    }

    match /posts/{postId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && isValidPost(incoming());
      allow update: if isSignedIn() && existing().userId == request.auth.uid
        && isValidPost(incoming())
        && incoming().diff(existing()).affectedKeys().hasOnly(['content', 'media', 'updatedAt']);
      allow delete: if isSignedIn() && existing().userId == request.auth.uid;
    }

    match /chats/{chatId}/messages/{messageId} {
      allow read: if isSignedIn(); // Simplified for now, usually check participants
      allow create: if isSignedIn() && incoming().senderId == request.auth.uid;
    }

    match /users/{userId}/notifications/{notiId} {
      allow read: if isOwner(userId);
      allow write: if false; // System only or very restricted
    }

    match /verification_requests/{requestId} {
      allow read: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && isValidVerificationRequest(incoming());
      allow update, delete: if false; // Only admins can update status
    }
  }
}
