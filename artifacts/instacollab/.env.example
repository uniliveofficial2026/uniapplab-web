# Copy to `.env` in this folder (never commit `.env`).
# Restart `pnpm dev` after editing.

# ─── UniAppLab domains (production) ───────────────────────────────────────────
# Local dev: leave VITE_APP_ORIGIN unset or use http://localhost:5173
# Vercel production: set these in Vercel → Settings → Environment Variables

VITE_APP_ORIGIN=https://app.uniapplab.com
VITE_SITE_URL=https://www.uniapplab.com
VITE_LANDING_URL=https://uniapplab.com
VITE_API_URL=https://api.uniapplab.com
VITE_LIVE_URL=https://live.uniapplab.com
VITE_CALL_URL=https://call.uniapplab.com
VITE_CHAT_URL=https://chat.uniapplab.com
VITE_MEDIA_URL=https://media.uniapplab.com
VITE_CDN_URL=https://cdn.uniapplab.com
VITE_ADMIN_URL=https://admin.uniapplab.com

# Gemini (optional)
GEMINI_API_KEY=your_gemini_api_key

# Supabase — Dashboard → Project Settings → API
# Site URL in Supabase Auth: https://app.uniapplab.com
VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your_supabase_publishable_key
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key

# Google OAuth: pnpm run oauth:setup

# Firebase (optional fallback)
VITE_FIREBASE_API_KEY=YOUR_FIREBASE_API_KEY
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=000000000000
VITE_FIREBASE_APP_ID=1:000000000000:web:0000000000000000000000
VITE_FIREBASE_DATABASE_URL=https://your-project-default-rtdb.firebaseio.com
VITE_FIREBASE_MEASUREMENT_ID=G-XXXXXXXXXX
